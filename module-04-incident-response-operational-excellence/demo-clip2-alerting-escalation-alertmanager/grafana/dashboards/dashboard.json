{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Alert State Timeline",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(ALERTS{alertname=\"SLOBurnRateCritical\"}) or vector(0)",
          "legendFormat": "SLOBurnRateCritical",
          "refId": "A"
        },
        {
          "expr": "max(ALERTS{alertname=\"SLOBurnRateWarning\"}) or vector(0)",
          "legendFormat": "SLOBurnRateWarning",
          "refId": "B"
        },
        {
          "expr": "max(ALERTS{alertname=\"DependencyDown\"}) or vector(0)",
          "legendFormat": "DependencyDown",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "INACTIVE", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "FIRING", "color": "red" } }, "type": "value" }
          ],
          "noValue": "INACTIVE"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "alignValue": "left",
        "mergeValues": true,
        "rowHeight": 0.8
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(genai_requests_total{status=\"error\"}[1m])",
          "legendFormat": "errors/sec",
          "refId": "A"
        },
        {
          "expr": "rate(genai_requests_total{status=\"success\"}[1m])",
          "legendFormat": "success/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors/sec" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "success/sec" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Dependency Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "genai_dependency_up",
          "legendFormat": "{{ dep }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      }
    },
    {
      "title": "Burn Rate (error ratio x 1000)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(\n  rate(genai_requests_total{status=\"error\"}[1m])\n  /\n  rate(genai_requests_total[1m])\n) * 1000",
          "legendFormat": "burn rate x 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 14 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "Dependency Call Results",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(genai_dependency_calls_total[1m])",
          "legendFormat": "{{ dep }} — {{ result }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["genai", "alerting", "m4-clip2"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GenAI Alerting — Clip 2: Burn Rate, Routing, Inhibition",
  "uid": "m4-clip2-alerting",
  "version": 1
}
