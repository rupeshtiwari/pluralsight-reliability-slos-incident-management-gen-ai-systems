{
  "title": "SLO Compliance: GenAI API",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Error Budget Remaining (Demo Window)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "slo:error_budget_remaining_demo",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.2
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      }
    },
    {
      "type": "stat",
      "title": "Burn Rate Now (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "slo:burnrate_5m",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      }
    },
    {
      "type": "stat",
      "title": "Fast-Burn Page Alert",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(ALERTS{alertname=\"SLOFastBurnPage\",alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      }
    },
    {
      "type": "stat",
      "title": "Feature Freeze (Policy Gate)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "clamp_max(max(ALERTS{alertname=\"SLOFastBurnPage\",alertstate=\"firing\"}) or (slo:error_budget_remaining_demo < bool 0.2) or vector(0), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      }
    },
    {
      "type": "stat",
      "title": "Slow-Burn Ticket (Policy Gate)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(ALERTS{alertname=\"SLOSlowBurnTicket\",alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 5
      }
    },
    {
      "type": "text",
      "title": "Policy Branches",
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "options": {
        "mode": "markdown",
        "content": "**Fast-Burn \u2192 page + feature freeze**\n`burnrate_5m > 14.4 AND burnrate_1h > 14.4` (for 1m)\nFires in minutes. Blocks deploys immediately.\n\n**Slow-Burn \u2192 reliability work ticket**\n`burnrate_30m > 2 AND burnrate_6h > 2` (for 15m)\nQuiet budget drain. Creates a reliability work item for the next sprint."
      },
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 18,
        "h": 5
      }
    },
    {
      "type": "timeseries",
      "title": "Good vs Bad Request Rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(genai_requests_total{outcome=\"success\"}[5m]))",
          "legendFormat": "good",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(genai_requests_total{outcome!=\"success\"}[5m]))",
          "legendFormat": "bad",
          "refId": "B"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Burn Rate (5m and 1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "slo:burnrate_5m",
          "legendFormat": "5m",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "slo:burnrate_1h",
          "legendFormat": "1h",
          "refId": "B"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Top Dependency Errors (2m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "topk(3, sum by (dependency) (rate(genai_dependency_errors_total[2m])))",
          "legendFormat": "{{dependency}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Top Error Types (2m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "topk(3, sum by (dependency, error_type) (rate(genai_dependency_errors_total[2m])))",
          "legendFormat": "{{dependency}} {{error_type}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 7
      }
    }
  ]
}