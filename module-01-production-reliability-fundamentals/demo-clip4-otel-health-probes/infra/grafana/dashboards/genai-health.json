{
  "title": "GenAI Health + Probes",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "2s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Deep Probe Failures By Boundary",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (boundary, reason) (rate(probe_result_total{route=\"/probe/deep\",status=\"fail\"}[1m]))",
          "legendFormat": "{{boundary}} / {{reason}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Readiness State (1 ok, 0 degraded)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "ready_state",
          "legendFormat": "ready_state"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dependency Latency (p95)",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, boundary) (rate(dependency_latency_ms_bucket[1m])))",
          "legendFormat": "{{boundary}} p95"
        }
      ]
    }
  ]
}
